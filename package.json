{
  "name": "living-ink-diary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c \"#9b6b3d,#d3ad6f\" \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node --watch server/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/server.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "vite": "^8.1.3"
  }
}
